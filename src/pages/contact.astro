---
import Layout from '../layouts/Layout.astro';
import { Mail, Phone, MapPin, Send, HelpCircle } from 'lucide-react';
---

<Layout title="Contact Us | FlixCart">
  <div class="max-w-5xl mx-auto px-6 py-12 space-y-12 text-slate-300">
    
    <!-- Hero Block -->
    <div class="text-center space-y-4">
      <span class="inline-block text-[10px] font-black bg-brand-600 text-white px-3 py-1 rounded-md tracking-widest uppercase">
        GET IN TOUCH
      </span>
      <h1 class="text-4xl sm:text-5xl font-black text-white tracking-tight leading-none">
        Connect With Our Team
      </h1>
      <p class="text-sm text-slate-400 max-w-xl mx-auto leading-relaxed">
        Have questions about the FlixCart simulation, product listings, or custom integrations? Drop a line below.
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start pt-6">
      
      {/* Contact Card Details */}
      <div class="lg:col-span-5 space-y-6">
        <div class="bg-slate-950 border border-slate-900 rounded-3xl p-6 space-y-6">
          <h2 class="text-xl font-bold text-white border-b border-slate-900 pb-3 flex items-center gap-2">
            <HelpCircle className="h-5 w-5 text-brand-500" /> Support Desk
          </h2>
          
          <div class="space-y-4">
            <div class="flex items-start gap-4">
              <div class="h-9 w-9 rounded-lg bg-brand-500/10 flex items-center justify-center text-brand-500 shrink-0">
                <Mail className="h-4 w-4" />
              </div>
              <div>
                <h4 class="text-xs font-bold text-slate-400">EMAIL SUPPORT</h4>
                <p class="text-sm font-semibold text-white mt-0.5">contact@flixcart.com</p>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="h-9 w-9 rounded-lg bg-brand-500/10 flex items-center justify-center text-brand-500 shrink-0">
                <Phone className="h-4 w-4" />
              </div>
              <div>
                <h4 class="text-xs font-bold text-slate-400">CALL CENTER</h4>
                <p class="text-sm font-semibold text-white mt-0.5">+91 98765 43210</p>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="h-9 w-9 rounded-lg bg-brand-500/10 flex items-center justify-center text-brand-500 shrink-0">
                <MapPin className="h-4 w-4" />
              </div>
              <div>
                <h4 class="text-xs font-bold text-slate-400">HEADQUARTERS</h4>
                <p class="text-sm font-semibold text-white mt-0.5">New Delhi, India</p>
              </div>
            </div>
          </div>
        </div>
      </div>

      {/* Contact Form */}
      <div class="lg:col-span-7 bg-slate-950 border border-slate-900 rounded-3xl p-6 sm:p-8">
        <form id="contact-form" class="space-y-4">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="space-y-1.5">
              <label class="text-xs font-bold text-brand-500 uppercase">First Name</label>
              <input 
                type="text" required placeholder="Vishal"
                class="w-full px-4 py-2 bg-slate-900 border border-slate-800 rounded-xl focus:outline-none focus:border-brand-500 text-white text-sm"
              />
            </div>
            <div class="space-y-1.5">
              <label class="text-xs font-bold text-brand-500 uppercase">Email Address</label>
              <input 
                type="email" required placeholder="vishal@example.com"
                class="w-full px-4 py-2 bg-slate-900 border border-slate-800 rounded-xl focus:outline-none focus:border-brand-500 text-white text-sm"
              />
            </div>
          </div>

          <div class="space-y-1.5">
            <label class="text-xs font-bold text-brand-500 uppercase">Subject</label>
            <input 
              type="text" required placeholder="Simulated Inquiry"
              class="w-full px-4 py-2 bg-slate-900 border border-slate-800 rounded-xl focus:outline-none focus:border-brand-500 text-white text-sm"
            />
          </div>

          <div class="space-y-1.5">
            <label class="text-xs font-bold text-brand-500 uppercase">Your Message</label>
            <textarea 
              rows="4" required placeholder="Write your message here..."
              class="w-full px-4 py-2 bg-slate-900 border border-slate-800 rounded-xl focus:outline-none focus:border-brand-500 text-white text-sm resize-none"
            ></textarea>
          </div>

          <button
            type="submit"
            class="w-full py-3 bg-brand-600 hover:bg-brand-700 text-white font-bold rounded-xl shadow-lg transition-all hover:scale-101 flex items-center justify-center gap-1.5 cursor-pointer"
          >
            <Send className="h-4.5 w-4.5" /> Send Message
          </button>
        </form>

        {/* Success Modal Notification (Mock) */}
        <div id="contact-success" class="hidden text-center py-10 space-y-4">
          <div class="h-12 w-12 bg-emerald-500/10 border border-emerald-500/30 text-emerald-400 rounded-full flex items-center justify-center mx-auto">
            ✓
          </div>
          <h3 class="text-lg font-bold text-white">Message Sent Successfully!</h3>
          <p class="text-xs text-slate-400">Thanks for contacting us. This is a simulated inbox, your message was saved in session memory.</p>
          <button 
            type="button" 
            onclick="document.getElementById('contact-form').classList.remove('hidden'); document.getElementById('contact-success').classList.add('hidden');"
            class="px-4 py-1.5 bg-slate-850 hover:bg-slate-800 text-white rounded-lg text-xs font-bold"
          >
            Send Another
          </button>
        </div>
      </div>

    </div>

  </div>
</Layout>

<script is:inline>
  const form = document.getElementById('contact-form');
  const success = document.getElementById('contact-success');
  if (form && success) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      form.classList.add('hidden');
      success.classList.remove('hidden');
      form.reset();
    });
  }
</script>
